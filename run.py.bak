class engine:
    def engine_startupdate(self):
        events = pygame.event.get()
        keypoolz.getkey_upd(events)
        keypoolz.keybind_upd()
    def engine_physicupdate(self):
        # update
        for layer in globals()['maplayers']: #globals로 해. 난 몰라
            layer.next()

    # DEBUG
    #if keypoolz.keybind[pygame.K_SPACE][0]:
    #    maplayers[0].objects[0].dx += 3
    #    maplayers[0].objects[0].dy += 3
    #    mousepos = getmousexy()
    #    #swiggcam(mousepos[0], mousepos[1], 0.05)
    #    swizzlecam(0, 0, mousepos[0], mousepos[1], 0.1)
    #    effectz.new(5, mousepos[0]+WIDTH//2, mousepos[1]+HEIGHT//2, 5, (255,255,255), 30, 20, 0, [random.randint(-10, 10), random.randint(-10, 10),-0.1,10])
    # it fuckin works great hell yeah

    def engine_drawupdate(self):
        # drawing
        screen.fill(bgcolor)
        for layer in globals()['maplayers']: #아냐 globals로 해 그냥 건들지말고
            layer.render()
        globals()['effectz'].update(); screen.blit(globals()['effectz'].layer, (0, 0)) #아냐 아냐 난 몰라 그냥 냅둬 좀
        pygame.display.flip()
    def engine_endupate(self):
        clock.tick(60)

candlelist = {}
class candleMan:
    def __init__(self):
        self.redoit = False
    def newcandle(self, name):
        candlelist[name] = True
    def rmcandle(self, name):
        if name in candlelist:
            del candlelist[name]
    def togglecandle(self, name):
        if name in candlelist:
            candlelist[name] = not candlelist[name]
        else:
            candlelist[name] = True
    def redo(self):
        self.redoit = True

# load game
cman = candleMan()
enginez = engine()
keypoolz = keypool()
effectmanz = effectMan()
objectmanz = objectMan()
externalz = externalThings()
import importlib
spec = importlib.util.spec_from_file_location("owo", "game.py")
game = importlib.util.module_from_spec(spec)
spec.loader.exec_module(game)
count = game.SPINCOUNT

class bun: #bun 짬때리기
    #대파 양파 다진마늘 생강 계피 산초가루 깻잎 쑥갓 전복 새우 건새우 다시마 감초 쑥 등등 128개의 재료를 넣어주고,
    def __init__(self):
        self.shares = {}
    def getengine(self):
        return globals()['enginez']
    def change_value(self, name, val):
        globals()[name] = val
        return val
    def get_value(self, name):
        return globals().get(name)
    # 여기서 끝이 아니다. 사장님이 직접 만든 특제 비밀(?) 양념으로 무 다시마 표고버섯 통마늘 선지 월계수잎 팔각을 찜솥에 찐 다음 절구에 쥰내 비벼가지고 한데 넣어 푹 고아주면
    def Cengine(self, name):
        return globals()["enginez"].__getattribute__(name)()
    def Ckeypool(self, name, *args):
        return globals()["keypoolz"].__getattribute__(name)(*args)
    def CeffectMan(self, name, *args):
        return globals()["effectmanz"].__getattribute__(name)(*args)
    def CobjectMan(self, name, *args):
        return globals()["objectmanz"].__getattribute__(name)(*args)
    def CexternalThings(self, name, *args):
        return globals()["externalz"].__getattribute__(name)(*args)

# mainloop
while RUNNING:
    for counting in range(count):
        getattr(game, "exelayer"+str(counting))(bun) #함수명 개짜침
    #DoNotMakeMoreThan3LayersPleaseOrElseIWillCry(True) #becauseItMayGotTooMuchSlow
    isitend = False #도구 사용 피해를 피해자에게 전가하는 행위는 법률적, 윤리적으로 매우 부당한 상황으로, 주로 가해자가 자신의 책임을 회피하고 피해자를 탓하는(Victim Blaming) 전형적인 형태입니다. 이러한 상황은 범죄, 계약, 직장 등 다양한 분야에서 발생할 수 있습니다.
    while not isitend: #사례로는 보이스피싱, 메신저 피싱 등이 있습니다.
        isitend = True
        for candle in list(candlelist.keys()):
            if candlelist[candle]:
                getattr(game, candle)(bun)
            if cman.redoit:
                cman.redoit = False
                isitend = False
                break